Bootstrap: docker
From: pasapipeline/pasapipeline:2.5.3

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive

    if ! command -v apt-get >/dev/null 2>&1; then
        echo "apt-get is unavailable in the base image; cannot install blast support." >&2
        exit 1
    fi

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        ncbi-blast+ \
        ncbi-blast+-legacy
    rm -rf /var/lib/apt/lists/*

    cat >/usr/local/bin/blastall <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
args=()
while (($#)); do
    case "$1" in
        -G)
            shift
            if [[ "${1:-}" == "3" ]]; then
                args+=(-G 4)
            else
                args+=(-G "${1:-}")
            fi
            ;;
        -E)
            shift
            if [[ "${1:-}" == "3" ]]; then
                args+=(-E 4)
            else
                args+=(-E "${1:-}")
            fi
            ;;
        *)
            args+=("$1")
        ;;
    esac
    shift || true
done
exec /usr/bin/perl /usr/bin/legacy_blast blastall --path /usr/bin "${args[@]}"
EOF

    cat >/usr/local/bin/formatdb <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
exec /usr/bin/perl /usr/bin/legacy_blast formatdb --path /usr/bin "$@"
EOF

    chmod 0755 /usr/local/bin/blastall /usr/local/bin/formatdb
    command -v seqclean
    test -x /usr/local/src/PASApipeline/misc_utilities/accession_extractor.pl
    command -v blastall
    command -v formatdb

%labels
    Author FLyteTest
    Description PASA image with legacy BLAST support for seqclean
