#!/usr/bin/env bash
set -euo pipefail
args=()
while (($#)); do
  case "$1" in
    -G)
      shift
      if [[ "${1:-}" == "3" ]]; then
        args+=(-G 4)
      else
        args+=(-G "${1:-}")
      fi
      ;;
    -E)
      shift
      if [[ "${1:-}" == "3" ]]; then
        args+=(-E 4)
      else
        args+=(-E "${1:-}")
      fi
      ;;
    *)
      args+=("$1")
      ;;
  esac
  shift || true
done
exec /usr/bin/perl /usr/local/src/PASApipeline/blast-legacy-bridge/legacy_blast blastall --path /usr/local/src/PASApipeline/blast-legacy-bridge "${args[@]}"
