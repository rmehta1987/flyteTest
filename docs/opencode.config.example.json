{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "flytetest": {
      "type": "local",
      "enabled": true,
      "command": [
        "bash",
        "-lc",
        "cd /path/to/flyteTest && module load python/3.11.9 && source .venv/bin/activate && python -m flytetest.server"
      ],
      "environment": {
        "FLYTETEST_REPO_ROOT": "/path/to/flyteTest",
        "PYTHONPATH": "/path/to/flyteTest/src"
      }
    }
  }
}
