{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "flytetest": {
            "type": "local",
            "enabled": true,
            "command": [
                "bash",
                "-lc",
                "cd /scratch/midway3/mehta5/flyteTest && module load python/3.11.9 >/dev/null 2>&1 && source .venv/bin/activate 2>/dev/null && exec python -m flytetest.server"
            ],
            "environment": {
                "FLYTETEST_REPO_ROOT": "/scratch/midway3/mehta5/flyteTest",
                "PYTHONPATH": "/scratch/midway3/mehta5/flyteTest/src"
            }
        }
    },
    "watcher": {
        "ignore": [
            "docs/**",
            "results/**",
            ".runtime/**",
            "data/**",
            "__pycache__/**",
            "*.pyc",
            ".venv/**"
        ]
    }
}
